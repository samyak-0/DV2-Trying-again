{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Mean Coral Cover by Sector and Shelf Zone",
    "subtitle": "Outer-shelf reefs consistently support higher coral cover than inshore reefs — protection from runoff and fishing pressure is key",
    "subtitleColor": "#3d5a73",
    "subtitleFont": "DM Sans",
    "subtitleFontSize": 15
  },
  "width": "container",
  "height": 500,
  "data": {
    "url": "manta-tow-by-reef.csv"
  },
  "transform": [
    {
      "calculate": "datum.SHELF == 'I' ? 'Inshore' : datum.SHELF == 'M' ? 'Mid-Shelf' : 'Outer-Shelf'",
      "as": "Shelf_Location"
    },
    {
      "calculate": "datum.SECTOR == 'CG' ? 'Far North' : datum.SECTOR == 'PC' ? 'Princess Charlotte' : datum.SECTOR == 'CL' ? 'Cooktown–Lizard' : datum.SECTOR == 'CA' ? 'Cairns' : datum.SECTOR == 'IN' ? 'Innisfail' : datum.SECTOR == 'TO' ? 'Townsville' : datum.SECTOR == 'WH' ? 'Whitsundays' : datum.SECTOR == 'PO' ? 'Pompey' : datum.SECTOR == 'SW' ? 'Swains' : datum.SECTOR == 'CU' ? 'Capricorn–Bunker' : datum.SECTOR == 'CB' ? 'Mackay' : datum.SECTOR",
      "as": "Sector_Name"
    },
    {
      "aggregate": [
        {
          "op": "mean",
          "field": "MEAN_LIVE_CORAL",
          "as": "Mean_Coral"
        }
      ],
      "groupby": [
        "Sector_Name",
        "Shelf_Location"
      ]
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "y": {
      "field": "Sector_Name",
      "type": "nominal",
      "axis": {
        "title": null,
        "labelFontSize": 15
      },
      "sort": [
        "Far North",
        "Princess Charlotte",
        "Cooktown–Lizard",
        "Cairns",
        "Innisfail",
        "Townsville",
        "Whitsundays",
        "Pompey",
        "Swains",
        "Capricorn–Bunker",
        "Mackay"
      ]
    },
    "x": {
      "field": "Mean_Coral",
      "type": "quantitative",
      "axis": {
        "title": "Mean Live Coral Cover (%)",
        "grid": true
      },
      "scale": {
        "domain": [
          0,
          55
        ]
      }
    },
    "yOffset": {
      "field": "Shelf_Location"
    },
    "color": {
      "field": "Shelf_Location",
      "type": "nominal",
      "scale": {
        "domain": [
          "Inshore",
          "Mid-Shelf",
          "Outer-Shelf"
        ],
        "range": [
          "#89CFF0",
          "#0072B2",
          "#023e8a"
        ]
      },
      "legend": {
        "title": "Shelf Zone",
        "orient": "bottom",
        "direction": "horizontal",
        "titleFontSize": 15,
        "labelFontSize": 14
      }
    },
    "tooltip": [
      {
        "field": "Sector_Name",
        "type": "nominal",
        "title": "Sector"
      },
      {
        "field": "Shelf_Location",
        "type": "nominal",
        "title": "Shelf Zone"
      },
      {
        "field": "Mean_Coral",
        "type": "quantitative",
        "title": "Mean Coral Cover (%)",
        "format": ".1f"
      }
    ]
  },
  "config": {
    "background": "transparent",
    "title": {
      "color": "#0a1628",
      "font": "Playfair Display",
      "fontSize": 19,
      "anchor": "start",
      "fontWeight": "bold",
      "subtitleFont": "DM Sans",
      "subtitleFontSize": 15
    },
    "axis": {
      "domainColor": "#0a1628",
      "gridColor": "rgba(10,22,40,0.08)",
      "labelColor": "#0a1628",
      "tickColor": "#0a1628",
      "titleColor": "#0a1628",
      "labelFont": "DM Sans",
      "titleFont": "DM Sans",
      "labelFontSize": 14,
      "titleFontSize": 15
    },
    "legend": {
      "labelColor": "#0a1628",
      "titleColor": "#0a1628",
      "labelFont": "DM Sans",
      "titleFont": "DM Sans",
      "titleFontSize": 15,
      "labelFontSize": 14
    },
    "view": { "stroke": null }
  }
}